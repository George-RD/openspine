# .env.example — copy to .env and fill in real values before running.
# The .env file is gitignored; never commit it.

# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from BotFather.
OPENSPINE_TELEGRAM_BOT_TOKEN=

# ── Artifact encryption ───────────────────────────────────────────────────
# 32-byte hex key used to AES-256-GCM-encrypt artifact blobs on disk.
# Generate with: openssl rand -hex 32
OPENSPINE_ARTIFACT_KEY=

# ── Provider API keys (api_key auth mode) ─────────────────────────────────
# Anthropic API key (required if provider uses auth.mode = api_key).
ANTHROPIC_API_KEY=

# OpenAI-compat key if applicable.
# OPENAI_API_KEY=
